rules_version = '2';

// Firebase Storage Security Rules for WalkMyPet
service firebase.storage {
  match /b/{bucket}/o {

    // Allow authenticated users to upload profile images
    match /profile_images/{imageId} {
      // Allow read access to all authenticated users
      allow read: if request.auth != null;

      // Allow write access only to authenticated users
      // File must be an image and less than 5MB
      allow write: if request.auth != null
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');

      // Allow delete only if user owns the image
      allow delete: if request.auth != null;
    }

    // Allow authenticated users to upload pet images
    match /pet_images/{imageId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
      allow delete: if request.auth != null;
    }
  }
}
