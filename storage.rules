rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // WARNING: For testing purposes only.
    // These rules allow anyone to read and write images without authentication.
    // This should be secured before going into production.

    // FIXED: Match the actual upload path from the code
    match /profile_images/{imageId} {
      allow read, write: if true;
    }

    match /pet_images/{imageId} {
      allow read, write: if true;
    }
  }
}