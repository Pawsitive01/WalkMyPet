rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // ============================================================
    // HELPER FUNCTIONS
    // ============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isBookingParticipant(booking) {
      return isAuthenticated() &&
             (request.auth.uid == booking.ownerId ||
              request.auth.uid == booking.walkerId);
    }

    function isConversationParticipant(conversation) {
      return isAuthenticated() &&
             request.auth.uid in conversation.participantIds;
    }

    // Validate that protected fields haven't been tampered with
    function walkerProtectedFieldsUnchanged() {
      return !request.resource.data.diff(resource.data).affectedKeys()
        .hasAny(['walletBalance', 'totalEarnings', 'pendingEarnings',
                 'totalTransactions', 'completedWalks', 'rating', 'reviews']);
    }

    // ============================================================
    // WALKERS COLLECTION
    // ============================================================
    match /walkers/{walkerId} {
      // Anyone can read walker profiles (for discovery/booking)
      allow read: if true;

      // Only the walker can create their own profile
      allow create: if isAuthenticated() &&
                       request.auth.uid == walkerId &&
                       request.resource.data.id == walkerId;

      // Only the walker can update their own profile
      // Protected fields (wallet, earnings, stats) cannot be modified directly
      allow update: if isOwner(walkerId) &&
                       walkerProtectedFieldsUnchanged();

      // Only the walker can delete their own profile
      allow delete: if isOwner(walkerId);
    }

    // ============================================================
    // OWNERS COLLECTION
    // ============================================================
    match /owners/{ownerId} {
      // Anyone can read owner profiles (walkers need to see dog info)
      allow read: if true;

      // Only the owner can create their own profile
      allow create: if isAuthenticated() &&
                       request.auth.uid == ownerId &&
                       request.resource.data.id == ownerId;

      // Only the owner can update their own profile
      allow update: if isOwner(ownerId);

      // Only the owner can delete their own profile
      allow delete: if isOwner(ownerId);
    }

    // ============================================================
    // USERS COLLECTION (Legacy - for backward compatibility)
    // ============================================================
    match /users/{userId} {
      // Only the user can read/write their own data
      allow read, write: if isOwner(userId);
    }

    // ============================================================
    // BOOKINGS COLLECTION
    // ============================================================
    match /bookings/{bookingId} {
      // Only booking participants can read
      allow read: if isAuthenticated() &&
                     (request.auth.uid == resource.data.ownerId ||
                      request.auth.uid == resource.data.walkerId);

      // Only owners can create bookings
      allow create: if isAuthenticated() &&
                       request.auth.uid == request.resource.data.ownerId &&
                       request.resource.data.status == 'pending';

      // Only participants can update
      // Owners can: cancel, confirm completion
      // Walkers can: confirm/decline, mark complete, cancel
      allow update: if isAuthenticated() &&
                       (request.auth.uid == resource.data.ownerId ||
                        request.auth.uid == resource.data.walkerId) &&
                       // Ensure critical fields aren't tampered with
                       request.resource.data.ownerId == resource.data.ownerId &&
                       request.resource.data.walkerId == resource.data.walkerId &&
                       request.resource.data.price == resource.data.price;

      // Only participants can delete (cancel)
      allow delete: if isAuthenticated() &&
                       (request.auth.uid == resource.data.ownerId ||
                        request.auth.uid == resource.data.walkerId);
    }

    // ============================================================
    // RECURRING BOOKINGS COLLECTION
    // ============================================================
    match /recurring_bookings/{recurringId} {
      // Only participants can read
      allow read: if isAuthenticated() &&
                     (request.auth.uid == resource.data.ownerId ||
                      request.auth.uid == resource.data.walkerId);

      // Only owners can create recurring bookings
      allow create: if isAuthenticated() &&
                       request.auth.uid == request.resource.data.ownerId;

      // Only participants can update
      allow update: if isAuthenticated() &&
                       (request.auth.uid == resource.data.ownerId ||
                        request.auth.uid == resource.data.walkerId) &&
                       // Protect critical fields
                       request.resource.data.ownerId == resource.data.ownerId &&
                       request.resource.data.walkerId == resource.data.walkerId;

      // Only participants can delete
      allow delete: if isAuthenticated() &&
                       (request.auth.uid == resource.data.ownerId ||
                        request.auth.uid == resource.data.walkerId);
    }

    // ============================================================
    // REVIEWS COLLECTION
    // ============================================================
    match /reviews/{reviewId} {
      // Anyone can read reviews (public)
      allow read: if true;

      // Only authenticated users can create reviews for bookings they participated in
      // Users can only review the other party (not themselves)
      allow create: if isAuthenticated() &&
                       request.auth.uid == request.resource.data.reviewerId &&
                       request.auth.uid != request.resource.data.reviewedUserId;

      // Users can update their own reviews
      allow update: if isAuthenticated() &&
                       request.auth.uid == resource.data.reviewerId &&
                       // Prevent changing who was reviewed
                       request.resource.data.reviewedUserId == resource.data.reviewedUserId &&
                       request.resource.data.bookingId == resource.data.bookingId;

      // Users can delete their own reviews
      allow delete: if isAuthenticated() &&
                       request.auth.uid == resource.data.reviewerId;
    }

    // ============================================================
    // TRANSACTIONS COLLECTION
    // ============================================================
    match /transactions/{transactionId} {
      // Only the walker (who receives payment) can read their transactions
      // Owners cannot see transaction details (privacy)
      allow read: if isAuthenticated() &&
                     request.auth.uid == resource.data.userId;

      // No direct creation allowed - transactions are created by Cloud Functions
      allow create: if false;

      // No updates allowed - transactions are immutable
      allow update: if false;

      // No deletion allowed - keep financial records
      allow delete: if false;
    }

    // ============================================================
    // WITHDRAWAL REQUESTS COLLECTION
    // ============================================================
    match /withdrawal_requests/{requestId} {
      // Only the walker can read their own withdrawal requests
      allow read: if isAuthenticated() &&
                     request.auth.uid == resource.data.walkerId;

      // Only walkers can create withdrawal requests for themselves
      allow create: if isAuthenticated() &&
                       request.auth.uid == request.resource.data.walkerId &&
                       request.resource.data.status == 'pending';

      // Only the walker can update their own requests (e.g., cancel)
      // Cannot change amount or bank details after creation
      allow update: if isAuthenticated() &&
                       request.auth.uid == resource.data.walkerId &&
                       // Only status can change (to cancelled)
                       request.resource.data.amount == resource.data.amount &&
                       request.resource.data.walkerId == resource.data.walkerId;

      // Only the walker can delete their own requests
      allow delete: if isAuthenticated() &&
                       request.auth.uid == resource.data.walkerId;
    }

    // ============================================================
    // WALK TRACKING COLLECTION
    // ============================================================
    match /walk_tracking/{trackingId} {
      // Only booking participants can read tracking data
      allow read: if isAuthenticated() &&
                     (request.auth.uid == resource.data.ownerId ||
                      request.auth.uid == resource.data.walkerId);

      // Only the walker can create tracking for their bookings
      allow create: if isAuthenticated() &&
                       request.auth.uid == request.resource.data.walkerId;

      // Only the walker can update tracking
      allow update: if isAuthenticated() &&
                       request.auth.uid == resource.data.walkerId &&
                       // Protect critical fields
                       request.resource.data.bookingId == resource.data.bookingId &&
                       request.resource.data.walkerId == resource.data.walkerId &&
                       request.resource.data.ownerId == resource.data.ownerId;

      // Only the walker can delete tracking
      allow delete: if isAuthenticated() &&
                       request.auth.uid == resource.data.walkerId;
    }

    // ============================================================
    // CONVERSATIONS COLLECTION
    // ============================================================
    match /conversations/{conversationId} {
      // Only participants can read conversations
      allow read: if isAuthenticated() &&
                     request.auth.uid in resource.data.participantIds;

      // Only authenticated users can create conversations
      // Must include themselves as a participant
      allow create: if isAuthenticated() &&
                       request.auth.uid in request.resource.data.participantIds &&
                       request.resource.data.participantIds.size() == 2;

      // Only participants can update conversations
      allow update: if isAuthenticated() &&
                       request.auth.uid in resource.data.participantIds &&
                       // Participants cannot be changed
                       request.resource.data.participantIds == resource.data.participantIds;

      // Only participants can delete conversations
      allow delete: if isAuthenticated() &&
                       request.auth.uid in resource.data.participantIds;
    }

    // ============================================================
    // MESSAGES COLLECTION
    // ============================================================
    match /messages/{messageId} {
      // Only conversation participants can read messages
      // Note: This requires reading the conversation doc to check participants
      allow read: if isAuthenticated() &&
                     (request.auth.uid == resource.data.senderId ||
                      request.auth.uid == resource.data.receiverId);

      // Only authenticated users can create messages they're sending
      allow create: if isAuthenticated() &&
                       request.auth.uid == request.resource.data.senderId;

      // Only the sender can update their own messages (e.g., mark as edited)
      allow update: if isAuthenticated() &&
                       request.auth.uid == resource.data.senderId &&
                       // Cannot change sender/receiver
                       request.resource.data.senderId == resource.data.senderId &&
                       request.resource.data.receiverId == resource.data.receiverId;

      // Only the sender can delete their messages
      allow delete: if isAuthenticated() &&
                       request.auth.uid == resource.data.senderId;
    }

    // ============================================================
    // NOTIFICATIONS COLLECTION
    // ============================================================
    match /notifications/{notificationId} {
      // Only the target user can read their notifications
      allow read: if isAuthenticated() &&
                     request.auth.uid == resource.data.userId;

      // No direct creation allowed - created by Cloud Functions/system
      allow create: if false;

      // Only the target user can update (e.g., mark as read)
      allow update: if isAuthenticated() &&
                       request.auth.uid == resource.data.userId &&
                       // Cannot change the target user
                       request.resource.data.userId == resource.data.userId;

      // Only the target user can delete their notifications
      allow delete: if isAuthenticated() &&
                       request.auth.uid == resource.data.userId;
    }

    // ============================================================
    // SCHEDULED NOTIFICATIONS COLLECTION
    // ============================================================
    match /scheduled_notifications/{scheduledId} {
      // Only the target user can read
      allow read: if isAuthenticated() &&
                     request.auth.uid == resource.data.userId;

      // Only the target user can create scheduled notifications
      allow create: if isAuthenticated() &&
                       request.auth.uid == request.resource.data.userId;

      // Only the target user can update
      allow update: if isAuthenticated() &&
                       request.auth.uid == resource.data.userId;

      // Only the target user can delete
      allow delete: if isAuthenticated() &&
                       request.auth.uid == resource.data.userId;
    }

    // ============================================================
    // DEFAULT DENY
    // ============================================================
    // Deny all other access by default (secure by default)
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
